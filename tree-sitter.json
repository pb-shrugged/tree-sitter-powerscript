{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "powerscript",
      "camelcase": "Powerscript",
      "title": "Powerscript",
      "scope": "source.powerscript",
      "file-types": [
        "srs",
        "srf",
        "srw",
        "sru",
        "sra",
        "srm"
      ],
      "injection-regex": "^powerscript$",
      "class-name": "TreeSitterPowerscript"
    }
  ],
  "metadata": {
    "version": "0.0.2",
    "license": "MIT",
    "description": "Powerscript grammar for tree-sitter",
    "authors": [
      {
        "name": "Jose Cagnini"
      }
    ],
    "links": {
      "repository": "https://github.com/pb-shrugged/tree-sitter-powerscript"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
